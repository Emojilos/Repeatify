# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here
SUPABASE_ANON_KEY=your-anon-key-here

# JWT (used by backend for token verification)
JWT_SECRET=your-supabase-jwt-secret-here

# CORS: comma-separated allowed origins (required for production)
# Include your GitHub Pages URL and localhost for dev
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://yourusername.github.io
